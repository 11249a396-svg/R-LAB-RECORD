EmpID = c(1, 2, 3),
Name = c("Arun", "Divya", "Kiran"),
Dept = c("IT", "HR", "Finance")
)
salary <- data.frame(
EmpID = c(1, 2),
Basic = c(28000, 36000),
HRA = c(5600, 7200),
DA = c(2800, 3600)
)
rating <- data.frame(
EmpID = c(1, 3),
Rating = c(4.3, 4.9)
)
