Question 10: Merge (Student System)
students <- data.frame(
RollNo = c(10, 20, 30),
Name = c("Amit", "Pooja", "Rahul"),
Dept = c("IT", "CSE", "ECE")
)
marks <- data.frame(
RollNo = c(10, 20, 30),
Sem1 = c(65, 78, 88),
Sem2 = c(70, 80, 85)
)
attendance <- data.frame(
RollNo = c(10, 20, 30),
Attendance = c(90, 85, 88)
)
student_data <- merge(students, marks, by = "RollNo")
final_records <- merge(student_data, attendance, by = "RollNo")
final_records

Question 11: Payroll Merge
