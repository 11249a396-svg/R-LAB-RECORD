Question 1: University Course Enrollment
departments <- c("AI", "Data Science", "Cyber Security", "Civil")
students <- c(100, 90, 70, 50)
pie(
students,
labels = departments,
main = "Student Enrollment per Department",
col = c("lightblue", "yellow", "lightgreen", "pink")
)
barplot(
students,
names.arg = departments,
main = "Number of Students per Department",
xlab = "Department",
ylab = "Number of Students",
col = c("lightblue", "yellow", "lightgreen", "pink")
)

Question 2: Retail Store Sales Distribution
category <- c("Mobiles", "Footwear", "Groceries", "Furniture")
sales <- c(180000, 60000, 40000, 30000)
pie(
sales,
labels = category,
main = "Sales Distribution by Category",
col = rainbow(length(category))
)
barplot(
sales,
names.arg = category,
main = "Sales per Category",
xlab = "Category",
ylab = "Sales (₹)",
col = rainbow(length(category))
)

